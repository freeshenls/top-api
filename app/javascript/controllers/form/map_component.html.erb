<%# app/components/form/map_component.html.erb %>

<div data-form--map-component-target="container" 
     data-controller="form--map-component" 
     class="rounded-2xl overflow-hidden border border-gray-100 group relative transition-all duration-500 ease-in-out">
  
  <div class="absolute top-3 left-3 right-3 z-20 flex gap-2">
    <div class="relative flex-1">
      <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
        <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </div>
      <input type="text" 
             data-form--map-component-target="searchInput"
             placeholder="输入地点搜索..." 
             class="w-full bg-white/90 backdrop-blur-md border-none rounded-xl py-2.5 pl-9 pr-4 text-sm shadow-lg shadow-black/5 focus:ring-2 focus:ring-primary-500/20 transition-all">
      <div data-form--map-component-target="resultsContainer" class="absolute left-0 right-0 top-full mt-2 z-[9999] bg-white rounded-xl shadow-2xl border border-gray-100 max-h-60 overflow-y-auto"></div>
    </div>
    
    <button type="button" 
            data-action="click->form--map-component#toggleFullScreen"
            class="bg-white/90 backdrop-blur-sm p-2.5 rounded-xl shadow-lg hover:bg-primary-50 text-gray-600 transition-colors">
      <svg data-form--map-component-target="expandIcon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path data-form--map-component-target="iconPath" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
      </svg>
    </button>
  </div>

  <div data-form--map-component-target="map" class="w-full <%= @height %> bg-gray-50 z-10 transition-all duration-500"></div>
  
  <%= @form.hidden_field :lng, data: { "form--map-component-target": "lng" } %>
  <%= @form.hidden_field :lat, data: { "form--map-component-target": "lat" } %>
</div>
