<%= turbo_frame_tag "auth_frame" do %>
  <div class="w-full max-w-[420px] mx-auto overflow-hidden transition-all">
    <div class="text-center mb-8">
      <div class="h-16 w-16 bg-gradient-to-br from-[#0EA5E9] to-[#0369A1] rounded-2xl flex items-center justify-center shadow-lg shadow-sky-200 mx-auto mb-6">
        <%= image_tag asset_path('logo.svg'), class: "h-10 w-10 brightness-0 invert", alt: "Logo" %>
      </div>
      <h2 class="text-2xl font-black text-slate-800 tracking-tight">修改登录密码</h2>
      <p class="text-sm text-slate-400 mt-2 font-medium">保障您的账号与数据安全</p>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-6", data: { turbo: false } }) do |f| %>
      <% if resource.errors.any? %>
        <div class="bg-red-50 border border-red-200 text-red-600 px-5 py-4 rounded-2xl text-xs space-y-1">
          <% resource.errors.full_messages.each do |message| %>
            <p>• <%= message %></p>
          <% end %>
        </div>
      <% end %>

      <div class="space-y-5">
        <div class="space-y-2">
          <%= f.label :current_password, "当前旧密码", class: "block text-[11px] font-black text-slate-400 uppercase tracking-widest ml-1" %>
          <div class="relative" data-controller="password-visibility">
            <%= f.password_field :current_password, autocomplete: "current-password", 
                class: "w-full bg-slate-50 border-none rounded-2xl py-4 px-5 text-sm focus:ring-2 focus:ring-sky-500/20 transition-all pr-12", 
                placeholder: "请输入您目前使用的密码", data: { password_visibility_target: "input" } %>
            <button type="button" data-action="password-visibility#toggle" class="absolute inset-y-0 right-0 w-12 flex items-center justify-center text-slate-300 hover:text-sky-500 transition-colors">
               <span data-password-visibility-target="icon"><%= heroicon "eye-slash", variant: :outline, options: { class: "h-5 w-5" } %></span>
               <span class="hidden" data-password-visibility-target="icon"><%= heroicon "eye", variant: :outline, options: { class: "h-5 w-5" } %></span>
            </button>
          </div>
        </div>

        <div class="h-px bg-slate-100 mx-4"></div>

        <div class="space-y-2">
          <%= f.label :password, "设置新密码", class: "block text-[11px] font-black text-slate-400 uppercase tracking-widest ml-1" %>
          <div class="relative" data-controller="password-visibility">
            <%= f.password_field :password, autocomplete: "new-password", 
                class: "w-full bg-slate-50 border-none rounded-2xl py-4 px-5 text-sm focus:ring-2 focus:ring-sky-500/20 transition-all pr-12", 
                placeholder: "新密码 (不少于 6 位字符)", data: { password_visibility_target: "input" } %>
            <button type="button" data-action="password-visibility#toggle" class="absolute inset-y-0 right-0 w-12 flex items-center justify-center text-slate-300 hover:text-sky-500 transition-colors">
               <span data-password-visibility-target="icon"><%= heroicon "eye-slash", variant: :outline, options: { class: "h-5 w-5" } %></span>
               <span class="hidden" data-password-visibility-target="icon"><%= heroicon "eye", variant: :outline, options: { class: "h-5 w-5" } %></span>
            </button>
          </div>
        </div>

        <div class="space-y-2">
          <%= f.label :password_confirmation, "再次确认新密码", class: "block text-[11px] font-black text-slate-400 uppercase tracking-widest ml-1" %>
          <div class="relative" data-controller="password-visibility">
            <%= f.password_field :password_confirmation, autocomplete: "new-password", 
                class: "w-full bg-slate-50 border-none rounded-2xl py-4 px-5 text-sm focus:ring-2 focus:ring-sky-500/20 transition-all pr-12", 
                placeholder: "请再次输入新密码", data: { password_visibility_target: "input" } %>
            <button type="button" data-action="password-visibility#toggle" class="absolute inset-y-0 right-0 w-12 flex items-center justify-center text-slate-300 hover:text-sky-500 transition-colors">
               <span data-password-visibility-target="icon"><%= heroicon "eye-slash", variant: :outline, options: { class: "h-5 w-5" } %></span>
               <span class="hidden" data-password-visibility-target="icon"><%= heroicon "eye", variant: :outline, options: { class: "h-5 w-5" } %></span>
            </button>
          </div>
        </div>
      </div>

      <div class="pt-4">
        <%= f.submit "确认修改密码", class: "w-full bg-gradient-to-r from-[#0EA5E9] to-[#0369A1] text-white py-4 rounded-2xl font-black text-sm shadow-xl shadow-sky-500/20 hover:brightness-110 active:scale-[0.98] transition-all cursor-pointer" %>
      </div>
    <% end %>
  </div>
<% end %>

