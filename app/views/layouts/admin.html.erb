<!DOCTYPE html>
<html>
  <head>
    <title>AI 领航 | 管理后台</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "application", "data-turbo-track": "reload" %>
    <link rel="icon" href="<%= asset_path('logo.svg') %>" type="image/svg+xml">
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-50 font-sans antialiased text-slate-900">
    <div class="min-h-screen flex" data-controller="mobile-menu">
      <!-- 侧边栏 (Desktop) -->
      <aside class="hidden lg:flex w-64 bg-slate-900 text-slate-300 flex flex-col sticky top-0 h-screen">
        <div class="p-6 flex items-center gap-3 border-b border-slate-800">
          <div class="h-8 w-8 bg-gradient-to-br from-[#0EA5E9] to-[#0369A1] rounded-lg flex items-center justify-center shadow-sm flex-shrink-0">
            <%= image_tag asset_path('logo.svg'), class: "h-5 w-5 brightness-0 invert", alt: "Logo" %>
          </div>
          <span class="font-bold text-white tracking-tight">AI 领航</span>
        </div>

        <%= render 'admin/shared/navigation' %>

        <div class="p-4 border-t border-slate-800">
          <%= link_to root_path, class: "flex items-center gap-3 px-4 py-2 text-xs font-medium text-slate-500 hover:text-white transition-colors" do %>
            <%= heroicon "arrow-left-start-on-rectangle", variant: :outline, options: { class: "h-4 w-4" } %>
            返回前台
          <% end %>
        </div>
      </aside>

      <!-- 移动端抽屉式菜单 (Mobile Menu Drawer) -->
      <div data-mobile-menu-target="menu" class="hidden fixed inset-0 z-[100] lg:hidden">
        <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm" data-action="click->mobile-menu#hide"></div>
        <div class="absolute inset-y-0 left-0 w-72 bg-slate-900 shadow-2xl flex flex-col animate-in slide-in-from-left duration-300">
          <div class="p-6 border-b border-slate-800 flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="h-8 w-8 bg-gradient-to-br from-[#0EA5E9] to-[#0369A1] rounded-lg flex items-center justify-center">
                <%= image_tag asset_path('logo.svg'), class: "h-5 w-5 brightness-0 invert" %>
              </div>
              <span class="font-bold text-white tracking-tight">管理菜单</span>
            </div>
            <button data-action="click->mobile-menu#hide" class="p-2 text-slate-400 hover:text-white transition-colors">
              <%= heroicon "x-mark", variant: :outline, options: { class: "h-6 w-6" } %>
            </button>
          </div>
          <div class="flex-1 overflow-y-auto">
            <%= render 'admin/shared/navigation', is_mobile: true %>
          </div>
          <div class="p-6 border-t border-slate-800">
            <%= link_to root_path, class: "flex items-center gap-3 px-4 py-2 text-sm font-medium text-slate-400 hover:text-white transition-colors" do %>
              <%= heroicon "arrow-left-start-on-rectangle", variant: :outline, options: { class: "h-5 w-5" } %>
              返回前台
            <% end %>
          </div>
        </div>
      </div>

      <!-- 主体内容 -->
      <main class="flex-1 flex flex-col min-w-0">
        <!-- 顶部通栏 -->
        <header class="h-16 bg-white border-b border-slate-200 px-4 md:px-8 flex items-center justify-between">
          <div class="flex items-center gap-4">
            <button data-action="click->mobile-menu#toggle" class="lg:hidden p-2 -ml-2 text-slate-500 hover:text-sky-600 transition-colors">
              <%= heroicon "bars-3-bottom-left", variant: :outline, options: { class: "h-6 w-6" } %>
            </button>
            <% 
              controller_titles = {
                'dashboard' => '概览仪表盘',
                'users' => '用户管理',
                'carousel_items' => '首页轮播',
                'posts' => '最新动态',
                'activities' => '线下活动',
                'categories' => '分类管理',
                'sites' => '站点管理'
              }
            %>
            <h2 class="text-sm font-bold text-slate-500 uppercase tracking-widest"><%= controller_titles[controller_name] || controller_name.humanize %></h2>
          </div>
          <div class="flex items-center gap-4">
             <span class="hidden sm:inline text-xs font-bold text-slate-400">当前管理员: <%= current_user.username %></span>
          </div>
        </header>

        <!-- 页面内容 -->
        <div class="p-4 md:p-8 relative flex-1 overflow-y-auto">
          <% if notice %>
            <div data-controller="notification"
                 data-notification-delay-value="3000"
                 class="fixed top-20 right-8 z-[100] transform transition-all duration-500 ease-in-out"
                 data-transition-enter-from="opacity-0 translate-x-10"
                 data-transition-enter-to="opacity-100 translate-x-0"
                 data-transition-leave-from="opacity-100 translate-x-0"
                 data-transition-leave-to="opacity-0 translate-x-10">
              <div class="bg-emerald-50 border border-emerald-100 text-emerald-700 px-6 py-4 rounded-2xl shadow-xl shadow-emerald-500/10 flex items-center gap-3">
                <div class="h-8 w-8 bg-emerald-500 rounded-full flex items-center justify-center text-white">
                  <%= heroicon "check", variant: :solid, options: { class: "h-4 w-4" } %>
                </div>
                <div>
                  <p class="font-bold text-sm">操作成功</p>
                  <p class="text-xs text-emerald-600/80"><%= notice %></p>
                </div>
                <button data-action="notification#hide" class="ml-4 text-emerald-300 hover:text-emerald-500 transition-colors">
                  <%= heroicon "x-mark", variant: :solid, options: { class: "h-4 w-4" } %>
                </button>
              </div>
            </div>
          <% end %>

          <% if alert %>
            <div data-controller="notification"
                 data-notification-delay-value="3000"
                 class="fixed top-20 right-8 z-[100] transform transition-all duration-500 ease-in-out">
              <div class="bg-red-50 border border-red-100 text-red-700 px-6 py-4 rounded-2xl shadow-xl shadow-red-500/10 flex items-center gap-3">
                <div class="h-8 w-8 bg-red-500 rounded-full flex items-center justify-center text-white text-xs">!</div>
                <div>
                  <p class="font-bold text-sm">提醒</p>
                  <p class="text-xs text-red-600/80"><%= alert %></p>
                </div>
                <button data-action="notification#hide" class="ml-4 text-red-300 hover:text-red-500">
                  <%= heroicon "x-mark", variant: :solid, options: { class: "h-4 w-4" } %>
                </button>
              </div>
            </div>
          <% end %>

          <%= yield %>
        </div>
      </main>
    </div>
  </body>
</html>
