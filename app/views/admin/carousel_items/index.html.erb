<%# app/views/admin/carousel_items/index.html.erb %>

<div class="mb-8 flex flex-col md:flex-row md:items-center justify-between gap-6">
  <div>
    <h2 class="text-2xl font-black text-slate-800 tracking-tight">轮播图内容管理</h2>
    <p class="text-slate-400 text-sm mt-1">管理首页大屏轮播展示、跳转链接及显示权重</p>
  </div>
  
  <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4 w-full md:w-auto">
    <%= form_with url: admin_carousel_items_path, method: :get, class: "flex items-center gap-2 flex-1", data: { turbo_frame: "admin_carousel_items_list", turbo_action: "advance" } do |f| %>
      <div class="relative w-full">
        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-400">
          <%= heroicon "magnifying-glass", variant: :outline, options: { class: "h-4 w-4" } %>
        </div>
        <%= f.text_field :q, value: params[:q], placeholder: "搜索轮播标题...", 
            class: "bg-white border-slate-200 rounded-2xl py-2.5 pl-10 pr-4 text-sm w-full md:w-64 focus:ring-sky-500 focus:border-sky-500 transition-all shadow-sm",
            oninput: "this.form.requestSubmit()" %>
      </div>
    <% end %>

    <%= link_to new_admin_carousel_item_path, class: "flex items-center justify-center gap-2 px-6 py-3 bg-sky-600 text-white rounded-2xl text-sm font-bold shadow-lg shadow-sky-200 hover:bg-sky-700 transition-all whitespace-nowrap" do %>
      <%= heroicon "plus", variant: :solid, options: { class: "h-5 w-5" } %>
      添加轮播图
    <% end %>
  </div>
</div>

<div class="bg-white rounded-[2.5rem] shadow-sm border border-slate-100 overflow-hidden">
  <div class="p-8 border-b border-slate-100 flex items-center justify-between bg-slate-50/30">
    <h3 class="text-xl font-black text-slate-800 tracking-tight text-sky-600">已发布轮播</h3>
  </div>

  <div class="overflow-x-auto">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="bg-slate-50/50 text-[10px] font-black text-slate-400 uppercase tracking-widest">
          <th class="p-6">顺序</th>
          <th class="p-6">标题与说明</th>
          <th class="p-6">预览图 URL</th>
          <th class="p-6 text-center">状态</th>
          <th class="p-6 text-right">操作</th>
        </tr>
      </thead>
      <tbody id="admin_carousel_items_list" class="divide-y divide-slate-50">
        <%= render partial: "carousel_item_row", collection: @carousel_items, as: :carousel_item %>
      </tbody>
    </table>

    <% if @pagy.next %>
      <div id="infinite_scroll_trigger" class="py-10" data-controller="infinite-scroll">
        <%= link_to "加载更多", admin_carousel_items_path(page: @pagy.next, q: params[:q]), 
            class: "hidden", data: { turbo_stream: true } %>
      </div>
    <% end %>
  </div>
</div>
