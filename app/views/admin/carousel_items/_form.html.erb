<%# app/views/admin/carousel_items/_form.html.erb %>

<%= form_with(model: [:admin, carousel_item], class: "bg-white rounded-[2.5rem] shadow-sm border border-slate-100 p-10 space-y-8") do |f| %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    <div class="space-y-2">
      <%= f.label :title, "轮播标题", class: "text-sm font-bold text-slate-700 ml-1" %>
      <%= f.text_field :title, class: "w-full bg-slate-50 border-slate-200 rounded-2xl py-3 px-5 text-sm focus:ring-sky-500 focus:border-sky-500", placeholder: "例如：AI 教程学院" %>
    </div>
    <div class="space-y-2">
      <%= f.label :position, "显示顺序 (数字越小越靠前)", class: "text-sm font-bold text-slate-700 ml-1" %>
      <%= f.number_field :position, class: "w-full bg-slate-50 border-slate-200 rounded-2xl py-3 px-5 text-sm focus:ring-sky-500 focus:border-sky-500" %>
    </div>
  </div>

  <div class="space-y-2">
    <%= f.label :description, "描述文字", class: "text-sm font-bold text-slate-700 ml-1" %>
    <%= f.text_field :description, class: "w-full bg-slate-50 border-slate-200 rounded-2xl py-3 px-5 text-sm focus:ring-sky-500 focus:border-sky-500", placeholder: "一段吸引人的简短介绍" %>
  </div>

  <div class="space-y-2">
    <%= f.label :image, "图片 URL (建议尺寸 1200x600)", class: "text-sm font-bold text-slate-700 ml-1" %>
    <%= f.text_field :image, class: "w-full bg-slate-50 border-slate-200 rounded-2xl py-3 px-5 text-sm focus:ring-sky-500 focus:border-sky-500", placeholder: "https://example.com/image.jpg" %>
  </div>

  <div class="space-y-2">
    <%= f.label :link, "跳转链接", class: "text-sm font-bold text-slate-700 ml-1" %>
    <%= f.text_field :link, class: "w-full bg-slate-50 border-slate-200 rounded-2xl py-3 px-5 text-sm focus:ring-sky-500 focus:border-sky-500", placeholder: "/pricing 或外部链接" %>
  </div>

  <div class="flex items-center gap-2">
    <%= f.check_box :active, class: "rounded text-sky-600 focus:ring-sky-500" %>
    <%= f.label :active, "立即发布显示", class: "text-sm font-bold text-slate-700" %>
  </div>

  <div class="pt-4 flex gap-4">
    <%= f.submit "保存设置", class: "px-8 py-3 bg-sky-600 text-white rounded-2xl text-sm font-bold shadow-lg shadow-sky-200 hover:bg-sky-700 transition-all cursor-pointer" %>
    <%= link_to "取消", admin_carousel_items_path, class: "px-8 py-3 bg-slate-100 text-slate-600 rounded-2xl text-sm font-bold hover:bg-slate-200 transition-all" %>
  </div>
<% end %>
