<tr class="hover:bg-slate-50 transition-colors group">
  <td class="p-6">
    <span class="px-3 py-1 bg-sky-50 text-sky-600 rounded-lg text-[10px] font-bold"><%= site.category&.name %></span>
  </td>
  <td class="p-6">
    <div>
      <p class="text-sm font-bold text-slate-800"><%= site.name %></p>
      <p class="text-[10px] text-slate-400 line-clamp-1"><%= site.url %></p>
    </div>
  </td>
  <td class="p-6">
    <div class="h-10 w-10 bg-slate-50 rounded-xl overflow-hidden border border-slate-100 p-1">
      <% if site.icon_url.present? %>
        <img src="<%= site.icon_url %>" class="h-full w-full object-contain">
      <% else %>
        <div class="h-full w-full flex items-center justify-center text-slate-200">
          <%= heroicon "globe-alt", variant: :outline, options: { class: "h-5 w-5" } %>
        </div>
      <% end %>
    </div>
  </td>
  <td class="p-6 text-center">
    <% if site.active %>
      <span class="px-3 py-1 bg-green-50 text-green-600 rounded-full text-[10px] font-black ring-1 ring-green-200">上线中</span>
    <% else %>
      <span class="px-3 py-1 bg-slate-100 text-slate-400 rounded-full text-[10px] font-bold">已下架</span>
    <% end %>
  </td>
  <td class="p-6 text-right">
    <div class="flex items-center justify-end gap-2">
      <%= link_to edit_admin_site_path(site), class: "p-2 text-slate-400 hover:text-sky-600 hover:bg-sky-50 rounded-lg transition-all" do %>
        <%= heroicon "pencil-square", variant: :outline, options: { class: "h-5 w-5" } %>
      <% end %>
      <%= button_to admin_site_path(site), method: :delete, data: { confirm: '确定删除吗？' }, class: "p-2 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-all" do %>
        <%= heroicon "trash", variant: :outline, options: { class: "h-5 w-5" } %>
      <% end %>
    </div>
  </td>
</tr>
