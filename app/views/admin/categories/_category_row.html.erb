<tr class="hover:bg-slate-50 transition-colors group">
  <td class="p-6">
    <span class="font-mono text-slate-400"><%= category.position %></span>
  </td>
  <td class="p-6">
    <span class="text-sm font-bold text-slate-800"><%= category.name %></span>
  </td>
  <td class="p-6">
    <div class="flex items-center gap-2">
      <div class="h-8 w-8 bg-slate-50 rounded-lg flex items-center justify-center text-sky-500">
        <%= heroicon category.icon.presence || "squares-2x2", variant: :outline, options: { class: "h-5 w-5" } %>
      </div>
      <span class="text-[10px] text-slate-400 font-mono"><%= category.icon %></span>
    </div>
  </td>
  <td class="p-6 text-center">
    <% if category.active %>
      <span class="px-3 py-1 bg-green-50 text-green-600 rounded-full text-[10px] font-black ring-1 ring-green-200">启用中</span>
    <% else %>
      <span class="px-3 py-1 bg-slate-100 text-slate-400 rounded-full text-[10px] font-bold">已禁用</span>
    <% end %>
  </td>
  <td class="p-6 text-right">
    <div class="flex items-center justify-end gap-2">
      <%= link_to edit_admin_category_path(category), class: "p-2 text-slate-400 hover:text-sky-600 hover:bg-sky-50 rounded-lg transition-all" do %>
        <%= heroicon "pencil-square", variant: :outline, options: { class: "h-5 w-5" } %>
      <% end %>
      <%= button_to admin_category_path(category), method: :delete, data: { confirm: '确定删除吗？这会同时删除该分类下的所有站点' }, class: "p-2 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-all" do %>
        <%= heroicon "trash", variant: :outline, options: { class: "h-5 w-5" } %>
      <% end %>
    </div>
  </td>
</tr>
