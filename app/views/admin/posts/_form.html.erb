<%# app/views/admin/posts/_form.html.erb %>

<%= form_with(model: [:admin, post], class: "bg-white rounded-[2.5rem] shadow-sm border border-slate-100 p-10 space-y-8") do |f| %>
  <div class="space-y-2">
    <%= f.label :title, "动态标题", class: "text-sm font-bold text-slate-700 ml-1" %>
    <%= f.text_field :title, class: "w-full bg-slate-50 border-slate-200 rounded-2xl py-3 px-5 text-sm focus:ring-sky-500 focus:border-sky-500", placeholder: "例如：社区升级公告" %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    <div class="space-y-2">
      <%= f.label :category, "分类", class: "text-sm font-bold text-slate-700 ml-1" %>
      <%= f.select :category, ["公告", "资讯", "更新"], {}, class: "w-full bg-slate-50 border-slate-200 rounded-2xl py-3 px-5 text-sm focus:ring-sky-500 focus:border-sky-500" %>
    </div>
    <div class="space-y-2">
      <%= f.label :published_at, "发布时间", class: "text-sm font-bold text-slate-700 ml-1" %>
      <%= f.datetime_local_field :published_at, class: "w-full bg-slate-50 border-slate-200 rounded-2xl py-3 px-5 text-sm focus:ring-sky-500 focus:border-sky-500" %>
    </div>
  </div>

  <div class="space-y-2">
    <%= f.label :content, "内容详情", class: "text-sm font-bold text-slate-700 ml-1" %>
    <%= f.text_area :content, rows: 6, class: "w-full bg-slate-50 border-slate-200 rounded-2xl py-3 px-5 text-sm focus:ring-sky-500 focus:border-sky-500", placeholder: "在此输入动态详情..." %>
  </div>

  <div class="pt-4 flex gap-4">
    <%= f.submit "发布动态", class: "px-8 py-3 bg-sky-600 text-white rounded-2xl text-sm font-bold shadow-lg shadow-sky-200 hover:bg-sky-700 transition-all cursor-pointer" %>
    <%= link_to "取消", admin_posts_path, class: "px-8 py-3 bg-slate-100 text-slate-600 rounded-2xl text-sm font-bold hover:bg-slate-200 transition-all" %>
  </div>
<% end %>
