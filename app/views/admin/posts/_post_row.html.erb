<tr class="hover:bg-slate-50 transition-colors group">
  <td class="p-6">
    <span class="text-xs font-mono text-slate-400"><%= post.published_at.strftime("%Y-%m-%d") %></span>
  </td>
  <td class="p-6">
    <p class="text-sm font-bold text-slate-800"><%= post.title %></p>
  </td>
  <td class="p-6">
    <span class="px-3 py-1 bg-sky-50 text-sky-600 rounded-full text-[10px] font-black uppercase tracking-wider">
      <%= post.category %>
    </span>
  </td>
  <td class="p-6 text-right">
    <div class="flex items-center justify-end gap-2">
      <%= link_to edit_admin_post_path(post), class: "p-2 text-slate-400 hover:text-sky-600 hover:bg-sky-50 rounded-lg transition-all" do %>
        <%= heroicon "pencil-square", variant: :outline, options: { class: "h-5 w-5" } %>
      <% end %>
      <%= button_to admin_post_path(post), method: :delete, data: { confirm: '确定删除吗？' }, class: "p-2 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-all" do %>
        <%= heroicon "trash", variant: :outline, options: { class: "h-5 w-5" } %>
      <% end %>
    </div>
  </td>
</tr>
