<dialog data-dialog-target="dialog" data-dialog-allow-click-outside-value="true" data-action="turbo:submit-end->dialog#submitEnd" class="backdrop:bg-slate-900/50 backdrop:backdrop-blur-sm rounded-[2.5rem] shadow-2xl p-0 w-full max-w-lg border-none bg-white animate-in fade-in zoom-in duration-300 m-auto max-h-[90vh] overflow-y-auto">
  <div class="relative p-8 lg:p-12">
    <!-- Close Button -->
    <button data-action="click->dialog#close" class="absolute top-6 right-6 h-10 w-10 flex items-center justify-center rounded-full bg-slate-50 text-slate-400 hover:bg-slate-100 hover:text-slate-600 transition-all border border-slate-100">
      <%= heroicon "x-mark", variant: :mini, options: { class: "h-5 w-5" } %>
    </button>



    <%= turbo_frame_tag "auth_frame" do %>
      <div class="flex items-center justify-center py-12">
        <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-sky-500"></div>
      </div>
    <% end %>
    

  </div>
</dialog>
