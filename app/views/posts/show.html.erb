<%# app/views/posts/show.html.erb %>

<div class="min-h-screen bg-slate-50 py-12 px-4">
  <div class="max-w-3xl mx-auto">
    <!-- 返回按钮 -->
    <%= link_to root_path, class: "inline-flex items-center gap-2 text-slate-400 hover:text-sky-600 transition-colors mb-8 group" do %>
      <div class="h-8 w-8 bg-white rounded-lg flex items-center justify-center shadow-sm group-hover:shadow-md transition-all">
        <%= heroicon "arrow-left", variant: :solid, options: { class: "h-4 w-4" } %>
      </div>
      <span class="text-sm font-bold">返回首页</span>
    <% end %>

    <article class="bg-white rounded-[2.5rem] shadow-xl shadow-slate-200/50 overflow-hidden border border-slate-100">
      <div class="p-8 md:p-12">
        <div class="flex items-center gap-3 mb-6">
          <span class="px-3 py-1 bg-sky-50 text-sky-600 rounded-full text-[10px] font-black uppercase tracking-widest ring-1 ring-sky-200">
            最新动态
          </span>
          <span class="text-slate-400 text-xs font-medium">
            发布于 <%= @post.published_at&.strftime("%Y年%m月%d日") %>
          </span>
        </div>

        <h1 class="text-3xl md:text-4xl font-black text-slate-900 mb-8 leading-tight tracking-tight">
          <%= @post.title %>
        </h1>

        <div class="prose prose-slate max-w-none">
          <div class="text-slate-600 leading-relaxed text-lg whitespace-pre-wrap font-medium">
            <%= @post.content %>
          </div>
        </div>
      </div>

      <div class="bg-slate-50 p-8 border-t border-slate-100 flex items-center justify-start">
         <div class="flex items-center gap-3">
           <div class="h-10 w-10 bg-sky-600 rounded-xl flex items-center justify-center">
             <%= image_tag asset_path('logo.svg'), class: "h-6 w-6 brightness-0 invert" %>
           </div>
           <div>
             <p class="text-sm font-bold text-slate-800">AI 领航官方</p>
             <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest">官方发布 · 圈子动态</p>
           </div>
         </div>
      </div>
    </article>
  </div>
</div>
