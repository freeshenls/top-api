<%# app/views/home/_sites_grid.html.erb %>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 xl:grid-cols-5 gap-6">
  <% if sites.any? %>
    <% sites.each do |site| %>
      <a href="<%= site.url %>" 
         target="_blank" 
         class="group/card bg-white p-5 rounded-[2rem] border border-slate-100 hover:border-sky-200 hover:shadow-xl hover:shadow-sky-500/5 transition-all transform hover:-translate-y-1 site-card"
         data-search-target="item"
         data-show-more-target="item"
         data-search-content="<%= [site.name, site.description].join(' ') %>">
        <div class="flex items-center gap-4 mb-4">
          <div class="h-12 w-12 bg-slate-50 rounded-2xl overflow-hidden p-2 group-hover/card:bg-sky-50 transition-colors border border-slate-50">
            <% if site.icon_url.present? %>
              <img src="<%= site.icon_url %>" class="h-full w-full object-contain" alt="<%= site.name %>" loading="lazy">
            <% else %>
              <div class="h-full w-full flex items-center justify-center text-slate-300 group-hover/card:text-sky-400">
                <%= heroicon "globe-alt", variant: :outline, options: { class: "h-6 w-6" } %>
              </div>
            <% end %>
          </div>
          <div class="flex-1 min-w-0">
            <h4 class="text-sm font-black text-slate-800 truncate mb-0.5 group-hover/card:text-sky-600 transition-colors"><%= site.name %></h4>
            <p class="text-[10px] text-slate-400 line-clamp-1"><%= site.description %></p>
          </div>
        </div>
        <div class="flex items-center justify-between pt-3 border-t border-slate-50">
          <span class="text-[9px] font-black text-slate-300 uppercase tracking-widest">立即访问</span>
          <%= heroicon "arrow-up-right", variant: :solid, options: { class: "h-3 w-3 text-slate-300 group-hover/card:text-sky-500 group-hover/card:translate-x-0.5 group-hover/card:-translate-y-0.5 transition-all" } %>
        </div>
      </a>
    <% end %>
  <% else %>
    <div class="col-span-full py-12 text-center border-2 border-dashed border-slate-100 rounded-[2.5rem]">
      <p class="text-sm text-slate-400 font-medium">该分类下暂无站点</p>
    </div>
  <% end %>
</div>
